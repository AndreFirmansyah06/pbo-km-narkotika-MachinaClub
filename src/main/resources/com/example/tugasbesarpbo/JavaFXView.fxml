<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tugasbesarpbo.view.FXMLController"
            prefHeight="400.0" prefWidth="600.0">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- ================= TOP: HEADER ================= -->
    <top>
        <VBox spacing="5">
            <padding>
                <Insets top="0" right="0" bottom="10" left="0"/>
            </padding>
            <children>
                <Label text="KNOWLEDGE MANAGEMENT SYSTEM"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label text="Putusan Pengadilan Narkotika"
                       style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
            </children>
        </VBox>
    </top>

    <left>
        <VBox spacing="8" prefWidth="280"
              style="-fx-background-color: #ecf0f1; -fx-background-radius: 5;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="📋 Form Input Putusan" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <TextField fx:id="txtNomorPerkara" promptText="Contoh: 1001/Pid.Sus/2024/PN Sby"/>

                <TextField fx:id="txtPengadilan" promptText="Nama Pengadilan Negeri"/>

                <TextField fx:id="txtTanggalPutusan" promptText="DD-MM-YYYY"/>

                <TextField fx:id="txtNamaTerdakwa" promptText="Nama lengkap terdakwa"/>

                <TextField fx:id="txtUmurTerdakwa" promptText="Usia dalam tahun"/>

                <ComboBox fx:id="cmbJenisNarkotika" value="Pilih jenis narkotika" maxWidth="Infinity">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Pilih jenis narkotika"/>
                            <String fx:value="Sabu-sabu"/>
                            <String fx:value="Ganja"/>
                            <String fx:value="Ekstasi"/>
                            <String fx:value="Heroin"/>
                            <String fx:value="Kokain"/>
                            <String fx:value="LSD"/>
                            <String fx:value="Putaw"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <TextField fx:id="txtBeratBarangBukti" promptText="Berat dalam gram"/>

                <TextField fx:id="txtPasalDilanggar" promptText="Contoh: Pasal 111 ayat (1)"/>

                <ComboBox fx:id="cmbPeranTerdakwa"
                          promptText="Pilih peran terdakwa"
                          maxWidth="Infinity">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Bandar"/>
                            <String fx:value="Pengedar"/>
                            <String fx:value="Kurir"/>
                            <String fx:value="Pengguna"/>
                            <String fx:value="Perantara"/>
                            <String fx:value="Penyimpan"/>
                            <String fx:value="Produsen"/>
                            <String fx:value="Lainnya"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <TextField fx:id="txtVonisHukuman" promptText="Lama hukuman (bulan)"/>

                <TextField fx:id="txtVonisDenda" promptText="Besaran denda (Rp)"/>

                <TextField fx:id="txtNamaHakim" promptText="Nama hakim ketua"/>

                <HBox spacing="10">
                    <children>
                        <Button fx:id="btnTambah" text="Tambah Putusan" maxWidth="Infinity"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"
                                onAction="#onTambahPutusan" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnUpdate" text="Update Putusan" maxWidth="Infinity"
                                style="-fx-background-color: #204ef5; -fx-text-fill: white; -fx-font-weight: bold;"
                                onAction="#onUpdatePutusan" HBox.hgrow="ALWAYS"/>

                    </children>
                </HBox>

                <HBox spacing="10">
                    <Button fx:id="btnHapus" text="Hapus Putusan" maxWidth="Infinity"
                            style="-fx-background-color: #f01d0a; -fx-text-fill: white; -fx-font-weight: bold;"
                            onAction="#onHapusPutusan" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnReset" text="Reset Form" maxWidth="Infinity"
                            style="-fx-background-color: #f0710a; -fx-text-fill: white;"
                            onAction="#onResetForm" HBox.hgrow="ALWAYS"/>
                </HBox>

            </children>
            <Button fx:id="btnUploadFile" text="Upload File (.csv)" maxWidth="Infinity"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;"
                    onAction="#onUploadFile" HBox.hgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ================= CENTER: TABEL DATA ================= -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <HBox spacing="10">
                    <children>
                        <VBox spacing="5">
                            <HBox spacing="10">
                                <Label text="Cari berdasarkan :"/>
                                <ComboBox fx:id="cbSearchMode" value="Nama" prefWidth="170">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Nama"/>
                                            <String fx:value="Nomor Perkara"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>
                            <HBox spacing="10">
                                <TextField fx:id="txtCari" promptText="Masukkan nomor perkara / nama terdakwa..."
                                           prefWidth="300"/>
                                <Button fx:id="btnCari" text="🔍 Cari" onAction="#onSearch"
                                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                            </HBox>

                        </VBox>

                        <VBox spacing="5" alignment="BOTTOM_CENTER">
                            <HBox spacing="5">
                                <Label text="Filter Berdasarakan Pengadilan:" prefWidth="190"/>
                                <ComboBox fx:id="cmbFilterPengadilan" value="Semua">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList" >
                                            <String fx:value="Semua"/>
                                            <String fx:value="Surabaya"/>
                                            <String fx:value="Malang"/>
                                            <String fx:value="Jakarta"/>
                                            <String fx:value="Bandung"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>

                            <HBox spacing="5">
                                <Label text="Filter Berdasarakan Jenis Narkotika:" prefWidth="190"/>
                                <ComboBox fx:id="cmbFilterJenis" value="Semua" >
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Semua"/>
                                            <String fx:value="Sabu-sabu"/>
                                            <String fx:value="Ganja"/>
                                            <String fx:value="Ekstasi"/>
                                            <String fx:value="Heroin"/>
                                            <String fx:value="Kokain"/>
                                            <String fx:value="LSD"/>
                                            <String fx:value="Putaw"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <Button fx:id="btnFilter" text="🔍 Filter" onAction="#onFilter"
                                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>

                            </HBox>
                        </VBox>
                    </children>
                </HBox>
                <HBox spacing="5">
                    <Label text="Rentang Vonis (bulan):"/>
                    <TextField fx:id="txtVonisMin" promptText="Min" prefWidth="80"/>
                    <Label text="s/d"/>
                    <TextField fx:id="txtVonisMax" promptText="Maks" prefWidth="80"/>
                    <Button fx:id="btnFilterVonis" text="🔍 Filter Vonis" onAction="#onFilterVonis"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                    <Button fx:id="btnResetFilter" text="❌ Reset Filter" onAction="#onResetFilter"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" alignment="BOTTOM_RIGHT"/>
                </HBox>
                <TableView fx:id="tablePutusan" prefHeight="500">
                    <columns>
                        <TableColumn fx:id="colNomor" text="Nomor Perkara" prefWidth="180"/>
                        <TableColumn fx:id="colNama" text="Nama Terdakwa" prefWidth="150"/>
                        <TableColumn fx:id="colJenis" text="Jenis Narkotika" prefWidth="120"/>
                        <TableColumn fx:id="colBerat" text="Berat (gr)" prefWidth="90"/>
                        <TableColumn fx:id="colVonis" text="Vonis (bln)" prefWidth="90"/>
                        <TableColumn fx:id="colPeran" text="Peran" prefWidth="100"/>
                        <TableColumn fx:id="colDenda" text="Denda" prefWidth="120"/>
                        <TableColumn fx:id="colHakim" text="Nama Hakim" prefWidth="120"/>
                    </columns>
                </TableView>

            </children>
            <Label fx:id="lblTotalData" text="Total: 0 data"/>
        </VBox>
    </center>

    <!-- ================= RIGHT: STATISTIK ================= -->
    <right>
        <VBox spacing="10" prefWidth="250"
              style="-fx-background-color: #ecf0f1; -fx-background-radius: 5;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="📊 Statistik Ringkasan" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Label fx:id="lblTotalPutusan" text="Total Putusan: 0" maxWidth="Infinity"
                       style="-fx-font-size: 12px; -fx-padding: 5px; -fx-background-color: white; -fx-background-radius: 3;"/>
                <Label fx:id="lblRataRataVonis" text="Rata-rata Vonis: 0 bulan" maxWidth="Infinity"
                       style="-fx-font-size: 12px; -fx-padding: 5px; -fx-background-color: white; -fx-background-radius: 3;"/>
                <Label fx:id="lblRataRataDenda" text="Rata-rata Denda: Rp 0" maxWidth="Infinity"
                       style="-fx-font-size: 12px; -fx-padding: 5px; -fx-background-color: white; -fx-background-radius: 3;"/>
                <Label fx:id="lblJenisTerbanyak" text="Jenis Terbanyak: -" maxWidth="Infinity"
                       style="-fx-font-size: 12px; -fx-padding: 5px; -fx-background-color: white; -fx-background-radius: 3;"/>

                <Label text="Distribusi Peran:" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="txtDistribusiPeran" editable="false" prefHeight="200"
                          style="-fx-font-family: monospace;"/>
            </children>
        </VBox>
    </right>

</BorderPane>
